# Google Gemini API Key
# Obtain from https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# Optional: Override default GPIO pins (Raspberry Pi)
# ULTRASONIC_TRIG=23
# ULTRASONIC_ECHO=24
# BUTTON_PIN=17
# BUZZER_PIN=27

# Optional: Obstacle threshold in centimeters
# OBSTACLE_THRESHOLD_CM=40.0
